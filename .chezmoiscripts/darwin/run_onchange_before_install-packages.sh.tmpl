#!/bin/bash

set -eufo pipefail

{{ $brews := list
     "bat"
     "curl"
     "git"
     "jq"
     "ripgrep"
     "tmux"
     "wget"
     "xz"
     "yt-dlp" -}}
{{ $casks := list
     "1password-cli"
     "karabiner-elements"
     "signal"
     "slack"
     "spotify"
     "vlc"
     "whatsapp" -}}

brew bundle --no-lock --file=/dev/stdin <<EOF
{{ range ($brews | sortAlpha | uniq) -}}
brew "{{ . }}"
{{ end -}}
{{ range ($casks | sortAlpha | uniq) -}}
cask "{{ . }}"
{{ end -}}
EOF
